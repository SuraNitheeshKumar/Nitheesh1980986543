<section id="contact" class="contact">
  <div class="slide-number">07 · Let's Connect</div>
  <div class="section-container">
    <p class="contact-cta">Open to Conversations — Strategy · Operations · Leadership</p>
    <div class="contact-links">
      <div class="contact-item">
        <svg class="contact-icon" data-lucide="mail"></svg>
        <span class="contact-text">{{contact.email}}</span>
      </div>
      <div class="contact-item">
        <svg class="contact-icon" data-lucide="linkedin"></svg>
        <span class="contact-text">{{contact.linkedin}}</span>
      </div>
      <div class="contact-item">
        <svg class="contact-icon" data-lucide="map-pin"></svg>
        <span class="contact-text">{{contact.location}}</span>
      </div>
    </div>
    <div class="contact-divider"></div>
    <p class="contact-footer">© 2025 S Nitheesh Kumar</p>
  </div>
</section>
